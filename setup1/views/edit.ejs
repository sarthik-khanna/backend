<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
      <a class="text-blue-600 inline-block mb-10" href="/">go to home</a>
      <form action="/edit" method="post">
        <input
          class="block px-5 py-2 bg-zinc-800 w-1/4 rounded-md outline-none"
          type="text"
          placeholder="previous name"
          name="previous"
          value="<%=filename%>"
        />
        <input
          type="text"
          class="block mt-2 px-5 py-2 w-1/4 m-2 rounded-md bg-zinc-800 resize-none outline-none"
          placeholder="new name"
          name="new"
        />
        <input
          class="mt-2 bg-yellow-600 px-5 py-2 rounded-md"
          type="submit"
          value="update name"
        />
      </form>
    </div>
  </body>
</html>
