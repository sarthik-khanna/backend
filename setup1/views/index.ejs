<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="main-w-full min-h-screen bg-zinc-900">
<div class="form p-10 text-white">
<form action="/create" method="post">
    <input  class="block px-5 py-2 bg-zinc-900 w-full rounded-md outline-none"  type="text" placeholder="title goes here" name="title">
    <textarea class="block mt-2 px-5 py-2 w-full rounded-md bg-zinc-800 resize-none outline-none" placeholder="write your task details" name="content"></textarea>
    <input class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="create task">
</form>
</div>

<div class="task p-10 flex gap-3 flex-wrap">
  <% if(files.length > 0){ %>
<%files.forEach(function(val){ %>
<div class="w-72  px-3 py-4 bg-zinc-800 rounded-md">
<h1 class="text-white text-2xl tracking-tighter"><%= val%></h1>
<div class="w-full  flex justify-between  mt-2">
<a class="text-blue-600 inline-block" href="/files/<%= val%>"> Read More</a>
<a class="text-zinc-600 " href="/edit/<%=val%>">Edit</a>
</div>
</div>
  <% }) %>
 <% } else { %>
<h1 class="bg-zinc-600">No task yet....</h1>
 <% } %>
<div class="w-72 hidden px-3 py-4 bg-zinc-800 rounded-md">
<h1 class="text-white text-2xl tracking-tighter">Some task goes here</h1>
<a class="text-blue-600 inline-block mt-2" href=""> Read More</a>
</div>
<div class="w-72 hidden px-3 py-4 bg-zinc-800 rounded-md">
<h1 class="text-white text-2xl tracking-tighter">Some task goes here</h1>
<a class="text-blue-600 inline-block mt-2" href=""> Read More</a>
</div>
<div class="w-72 hidden px-3 py-4 bg-zinc-800 rounded-md">
<h1 class="text-white text-2xl tracking-tighter">Some task goes here</h1>
<a class="text-blue-600 inline-block mt-2" href=""> Read More</a>
</div>

</div>
  </div>
</body>
</html>